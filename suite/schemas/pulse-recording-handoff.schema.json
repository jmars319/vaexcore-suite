{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vaexcore.local/suite/schemas/pulse-recording-handoff.schema.json",
  "title": "vaexcore Studio to Pulse recording handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestId",
    "sourceApp",
    "sourceAppName",
    "targetApp",
    "requestedAt",
    "recording"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "requestId": { "type": "string", "minLength": 1 },
    "sourceApp": { "type": "string", "const": "vaexcore-studio" },
    "sourceAppName": { "type": "string", "minLength": 1 },
    "targetApp": { "type": "string", "const": "vaexcore-pulse" },
    "requestedAt": { "type": "string", "format": "date-time" },
    "outputReady": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["ready", "state", "detail", "blockers", "warnings"],
      "properties": {
        "ready": { "type": "boolean" },
        "state": {
          "type": "string",
          "enum": ["ready", "degraded", "blocked", "not_applicable"]
        },
        "detail": { "type": "string", "minLength": 1 },
        "activeSceneId": { "type": ["string", "null"] },
        "activeSceneName": { "type": ["string", "null"] },
        "programPreviewFrameReady": { "type": ["boolean", "null"] },
        "compositorRenderPlanReady": { "type": ["boolean", "null"] },
        "outputPreflightReady": { "type": ["boolean", "null"] },
        "mediaPipelineReady": { "type": ["boolean", "null"] },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "recording": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessionId", "outputPath", "stoppedAt"],
      "properties": {
        "sessionId": { "type": "string", "minLength": 1 },
        "outputPath": { "type": "string", "minLength": 1 },
        "profileId": { "type": ["string", "null"] },
        "profileName": { "type": ["string", "null"] },
        "stoppedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
