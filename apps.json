{
  "schemaVersion": 1,
  "apps": [
    {
      "id": "vaexcore-studio",
      "name": "vaexcore studio",
      "repo": "https://github.com/jmars319/vaexcore-studio",
      "path": "studio",
      "branch": "main",
      "packageManager": "npm",
      "dependencyInstallCommand": "npm install",
      "windowsDistCommand": "npm run app:dist:windows",
      "windowsArtifactPatterns": [
        "studio\\target\\release\\bundle\\nsis\\*.exe",
        "studio\\target\\release\\bundle\\nsis\\*.msi"
      ],
      "macBuildCommand": "npm run tauri -w apps/desktop -- build --bundles app",
      "macArtifactSearchDir": "target/release/bundle",
      "artifactFolder": "studio"
    },
    {
      "id": "vaexcore-pulse",
      "name": "vaexcore pulse",
      "repo": "https://github.com/jmars319/vaexcore-pulse",
      "path": "pulse",
      "branch": "main",
      "packageManager": "pnpm",
      "dependencyInstallCommand": "pnpm install",
      "windowsDistCommand": "pnpm app:dist:windows",
      "windowsArtifactPatterns": [
        "pulse\\apps\\desktopapp\\src-tauri\\target\\release\\bundle\\nsis\\*.exe",
        "pulse\\apps\\desktopapp\\src-tauri\\target\\release\\bundle\\nsis\\*.msi"
      ],
      "macBuildCommand": "pnpm app:build",
      "macArtifactSearchDir": "release",
      "artifactFolder": "pulse"
    },
    {
      "id": "vaexcore-console",
      "name": "vaexcore console",
      "repo": "https://github.com/jmars319/vaexcore-console",
      "path": "console",
      "branch": "main",
      "packageManager": "npm",
      "dependencyInstallCommand": "npm install",
      "windowsDistCommand": "npm run app:dist:windows",
      "windowsArtifactPatterns": [
        "console\\release\\*.exe",
        "console\\release\\*.blockmap"
      ],
      "macBuildCommand": "npm run app:build",
      "macArtifactSearchDir": "release",
      "artifactFolder": "console"
    }
  ],
  "services": [
    {
      "id": "vaexcore-relay",
      "name": "vaexcore relay",
      "repo": "https://github.com/jmars319/vaexcore-relay",
      "path": "relay",
      "branch": "main",
      "packageManager": "npm",
      "dependencyInstallCommand": "npm install",
      "checkCommand": "npm run ci",
      "deployment": "cloudflare-worker",
      "remoteOptional": true
    }
  ]
}
